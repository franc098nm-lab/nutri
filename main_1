import React, { useState } from 'react';
import { Search, Activity, Droplet, Flame, Wheat, Star, AlertCircle, Loader2, Utensils, X, CalendarDays, Plus, PieChart, BookOpen, Sparkles, ChefHat, MessageSquareHeart } from 'lucide-react';

// API Ключ будет автоматически предоставлен окружением
const apiKey = import.meta.env.VITE_GEMINI_API_KEY;

// Функция для выполнения запросов с экспоненциальной задержкой
const fetchWithRetry = async (url, options, maxRetries = 5) => {
  let retries = 0;
  while (retries < maxRetries) {
    try {
      const response = await fetch(url, options);
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      return await response.json();
    } catch (error) {
      retries++;
      if (retries >= maxRetries) {
        throw error;
      }
      const delay = Math.pow(2, retries - 1) * 1000;
      await new Promise(resolve => setTimeout(resolve, delay));
    }
  }
};

// Компонент карточки поиска
function SearchResultCard({ dish, onRemove, onAddToDiary }) {
  const [weight, setWeight] = useState(100);
  const [recipe, setRecipe] = useState(null);
  const [loadingRecipe, setLoadingRecipe] = useState(false);

  const getRatingColor = (rating) => {
    if (rating >= 8) return 'text-emerald-500 bg-emerald-50 border-emerald-200';
    if (rating >= 5) return 'text-amber-500 bg-amber-50 border-amber-200';
    return 'text-rose-500 bg-rose-50 border-rose-200';
  };

  // Новая функция: Генерация здорового рецепта через Gemini API
  const generateRecipe = async () => {
    if (recipe) return; // Если рецепт уже сгенерирован, не генерируем заново
    
    setLoadingRecipe(true);
    const prompt = `Напиши полезный и здоровый пошаговый рецепт для блюда "${dish.name}". Напиши список ингредиентов и 3-4 шага приготовления. Будь краток. Не используй markdown-звездочки, используй обычные дефисы для списков.`;

    const payload = {
      contents: [{ parts: [{ text: prompt }] }],
      systemInstruction: { parts: [{ text: "Ты шеф-повар и эксперт по здоровому питанию. Твои рецепты вкусные, но низкокалорийные." }] }
    };

    try {
      const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
      const result = await fetchWithRetry(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const textResponse = result.candidates?.[0]?.content?.parts?.[0]?.text;
      if (textResponse) {
        setRecipe(textResponse);
      }
    } catch (err) {
      console.error("Ошибка при генерации рецепта:", err);
      setRecipe("Извините, не удалось сгенерировать рецепт. Попробуйте позже.");
    } finally {
      setLoadingRecipe(false);
    }
  };

  return (
    <div className="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 relative group animate-in slide-in-from-bottom-4 fade-in duration-300">
      <button 
        onClick={() => onRemove(dish.id)}
        className="absolute top-4 right-4 p-2 text-slate-300 hover:text-slate-500 hover:bg-slate-100 rounded-full transition-colors opacity-0 group-hover:opacity-100"
        title="Удалить из истории"
      >
        <X className="w-5 h-5" />
      </button>

      <div className="flex flex-col md:flex-row gap-6 md:items-start">
        {/* Левая колонка */}
        <div className="flex-1 space-y-4">
          <h2 className="text-2xl font-bold text-slate-800 pr-8">{dish.name}</h2>
          
          <div className="space-y-2">
            <div className="flex items-center gap-3">
              <span className="text-sm font-medium text-slate-500 uppercase tracking-wider">Индекс пользы</span>
              <div className={`px-3 py-1 rounded-full border flex items-center gap-1.5 font-bold ${getRatingColor(dish.healthRating)}`}>
                <Star className="w-4 h-4 fill-current" />
                {dish.healthRating} / 10
              </div>
            </div>
            <p className="text-slate-600 text-sm leading-relaxed">
              {dish.healthJustification}
            </p>
          </div>

          {/* Панель действий: Добавление в дневник и Генерация рецепта */}
          <div className="pt-4 mt-4 border-t border-slate-100 flex flex-wrap items-center gap-3">
            <div className="flex items-center bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
              <input 
                type="number" 
                min="1"
                value={weight}
                onChange={(e) => setWeight(e.target.value)}
                className="w-16 px-2 py-2 bg-transparent outline-none text-center font-medium text-slate-700"
              />
              <span className="px-3 py-2 text-slate-500 text-sm bg-slate-100 border-l border-slate-200">г</span>
            </div>
            <button 
              onClick={() => {
                onAddToDiary(dish, Number(weight));
                setWeight(100);
              }}
              className="flex items-center gap-2 px-4 py-2 bg-emerald-100 text-emerald-700 hover:bg-emerald-200 font-medium rounded-xl transition-colors"
            >
              <Plus className="w-4 h-4" />
              В дневник
            </button>
            
            <button 
              onClick={generateRecipe}
              disabled={loadingRecipe || recipe !== null}
              className="flex items-center gap-2 px-4 py-2 bg-purple-100 text-purple-700 hover:bg-purple-200 disabled:opacity-50 disabled:cursor-not-allowed font-medium rounded-xl transition-colors ml-auto"
            >
              {loadingRecipe ? (
                <Loader2 className="w-4 h-4 animate-spin" />
              ) : (
                <Sparkles className="w-4 h-4" />
              )}
              ✨ ИИ-Рецепт
            </button>
          </div>
          
          {/* Область для отображения рецепта */}
          {recipe && (
            <div className="mt-4 p-4 bg-purple-50 border border-purple-100 rounded-2xl animate-in fade-in duration-500">
              <div className="flex items-center gap-2 mb-2 text-purple-800 font-bold">
                <ChefHat className="w-5 h-5" />
                <h3>Здоровый рецепт от шефа</h3>
              </div>
              <p className="text-purple-900/80 text-sm whitespace-pre-wrap leading-relaxed">
                {recipe}
              </p>
            </div>
          )}
        </div>

        {/* Правая колонка: БЖУ и Калории */}
        <div className="grid grid-cols-2 gap-3 md:min-w-[300px]">
          <div className="bg-slate-50 p-3 rounded-2xl flex items-center gap-3">
            <div className="p-2 bg-orange-100 text-orange-600 rounded-xl">
              <Flame className="w-5 h-5" />
            </div>
            <div>
              <p className="text-xs text-slate-500 font-medium">Калории</p>
              <p className="font-bold text-slate-800">{dish.calories} <span className="text-[10px] font-normal text-slate-500">ккал</span></p>
            </div>
          </div>
          <div className="bg-slate-50 p-3 rounded-2xl flex items-center gap-3">
            <div className="p-2 bg-blue-100 text-blue-600 rounded-xl">
              <Activity className="w-5 h-5" />
            </div>
            <div>
              <p className="text-xs text-slate-500 font-medium">Белки</p>
              <p className="font-bold text-slate-800">{dish.protein} <span className="text-[10px] font-normal text-slate-500">г</span></p>
            </div>
          </div>
          <div className="bg-slate-50 p-3 rounded-2xl flex items-center gap-3">
            <div className="p-2 bg-yellow-100 text-yellow-600 rounded-xl">
              <Droplet className="w-5 h-5" />
            </div>
            <div>
              <p className="text-xs text-slate-500 font-medium">Жиры</p>
              <p className="font-bold text-slate-800">{dish.fat} <span className="text-[10px] font-normal text-slate-500">г</span></p>
            </div>
          </div>
          <div className="bg-slate-50 p-3 rounded-2xl flex items-center gap-3">
            <div className="p-2 bg-emerald-100 text-emerald-600 rounded-xl">
              <Wheat className="w-5 h-5" />
            </div>
            <div>
              <p className="text-xs text-slate-500 font-medium">Углеводы</p>
              <p className="font-bold text-slate-800">{dish.carbs} <span className="text-[10px] font-normal text-slate-500">г</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

export default function App() {
  const [activeTab, setActiveTab] = useState('search');
  
  const [dishInput, setDishInput] = useState('');
  const [history, setHistory] = useState([]);
  const [diary, setDiary] = useState([]);
  
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  
  // Состояния для ИИ-совета диетолога
  const [dietAdvice, setDietAdvice] = useState('');
  const [loadingAdvice, setLoadingAdvice] = useState(false);

  const analyzeDish = async (e) => {
    e.preventDefault();
    if (!dishInput.trim()) return;

    setLoading(true);
    setError('');

    const query = dishInput.trim();
    setDishInput('');

    const prompt = `Проанализируй блюдо или продукт: "${query}". Рассчитай примерную пищевую ценность строго на 100 грамм.`;
    const systemInstruction = "Ты эксперт-диетолог. Твоя задача оценивать состав блюд и их полезность. Возвращай строго JSON.";

    const payload = {
      contents: [{ parts: [{ text: prompt }] }],
      systemInstruction: { parts: [{ text: systemInstruction }] },
      generationConfig: {
        responseMimeType: "application/json",
        responseSchema: {
          type: "OBJECT",
          properties: {
            name: { type: "STRING", description: "Отформатированное название блюда с большой буквы" },
            calories: { type: "INTEGER", description: "Калории на 100г (ккал)" },
            protein: { type: "NUMBER", description: "Белки на 100г в граммах" },
            fat: { type: "NUMBER", description: "Жиры на 100г в граммах" },
            carbs: { type: "NUMBER", description: "Углеводы на 100г в граммах" },
            healthRating: { type: "INTEGER", description: "Рейтинг полезности от 1 до 10" },
            healthJustification: { type: "STRING", description: "Краткое обоснование рейтинга (1-2 предложения)" }
          },
          required: ["name", "calories", "protein", "fat", "carbs", "healthRating", "healthJustification"]
        }
      }
    };

    try {
      const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
      const result = await fetchWithRetry(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const textResponse = result.candidates?.[0]?.content?.parts?.[0]?.text;
      if (!textResponse) throw new Error("Пустой ответ от API");

      const data = JSON.parse(textResponse);
      setHistory(prev => [{ id: Date.now(), ...data }, ...prev]);
    } catch (err) {
      console.error("Ошибка при анализе:", err);
      setError('Не удалось проанализировать блюдо. Пожалуйста, попробуйте еще раз.');
      setDishInput(query);
    } finally {
      setLoading(false);
    }
  };

  const removeDishFromHistory = (idToRemove) => {
    setHistory(prev => prev.filter(item => item.id !== idToRemove));
  };

  const addToDiary = (dish, weight) => {
    if (weight <= 0) return;
    const factor = weight / 100;
    
    const diaryEntry = {
      id: Date.now() + Math.random(),
      name: dish.name,
      weight: weight,
      healthRating: dish.healthRating,
      calories: Math.round(dish.calories * factor),
      protein: Number((dish.protein * factor).toFixed(1)),
      fat: Number((dish.fat * factor).toFixed(1)),
      carbs: Number((dish.carbs * factor).toFixed(1)),
    };

    setDiary(prev => [diaryEntry, ...prev]);
    // При добавлении нового блюда сбрасываем старый совет, чтобы получить свежий
    setDietAdvice(''); 
  };

  const removeFromDiary = (idToRemove) => {
    setDiary(prev => prev.filter(item => item.id !== idToRemove));
    setDietAdvice('');
  };

  const dailyTotals = diary.reduce((acc, item) => ({
    calories: acc.calories + item.calories,
    protein: acc.protein + item.protein,
    fat: acc.fat + item.fat,
    carbs: acc.carbs + item.carbs,
  }), { calories: 0, protein: 0, fat: 0, carbs: 0 });

  // Новая функция: Совет диетолога на основе данных дневника
  const getNutritionAdvice = async () => {
    if (diary.length === 0) return;
    
    setLoadingAdvice(true);
    
    const eatenDishes = diary.map(d => `${d.name} (${d.weight}г)`).join(', ');
    const prompt = `Сегодня я съел: ${eatenDishes}. 
      Итого за день: ${dailyTotals.calories} ккал, Белки: ${dailyTotals.protein.toFixed(1)}г, Жиры: ${dailyTotals.fat.toFixed(1)}г, Углеводы: ${dailyTotals.carbs.toFixed(1)}г. 
      Дай мне дружелюбный и краткий совет как профессиональный диетолог (максимум 3 предложения). Скажи, сбалансирован ли мой рацион, чего не хватает, и предложи 1-2 конкретных блюда для следующего приема пищи, чтобы улучшить баланс БЖУ. Используй эмодзи.`;

    const payload = {
      contents: [{ parts: [{ text: prompt }] }],
      systemInstruction: { parts: [{ text: "Ты заботливый ИИ-диетолог." }] }
    };

    try {
      const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
      const result = await fetchWithRetry(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const textResponse = result.candidates?.[0]?.content?.parts?.[0]?.text;
      if (textResponse) {
        setDietAdvice(textResponse);
      }
    } catch (err) {
      console.error("Ошибка при получении совета:", err);
      setDietAdvice("Не удалось связаться с ИИ-диетологом. Попробуйте еще раз.");
    } finally {
      setLoadingAdvice(false);
    }
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans p-4 md:p-8">
      <div className="max-w-3xl mx-auto space-y-6">
        
        {/* Заголовок */}
        <header className="text-center space-y-3 pb-4">
          <div className="inline-flex items-center justify-center p-3 bg-emerald-100 rounded-2xl mb-2 shadow-sm">
            <Activity className="w-8 h-8 text-emerald-600" />
          </div>
          <h1 className="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight">
            Нутри-Аналитик
          </h1>
        </header>

        {/* Навигация (Табы) */}
        <div className="flex p-1 bg-slate-200/60 rounded-2xl max-w-sm mx-auto shadow-inner">
          <button
            onClick={() => setActiveTab('search')}
            className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-4 rounded-xl text-sm font-semibold transition-all ${
              activeTab === 'search' 
                ? 'bg-white text-emerald-700 shadow-sm' 
                : 'text-slate-500 hover:text-slate-700'
            }`}
          >
            <Search className="w-4 h-4" />
            Поиск блюд
          </button>
          <button
            onClick={() => setActiveTab('diary')}
            className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-4 rounded-xl text-sm font-semibold transition-all ${
              activeTab === 'diary' 
                ? 'bg-white text-emerald-700 shadow-sm' 
                : 'text-slate-500 hover:text-slate-700'
            }`}
          >
            <BookOpen className="w-4 h-4" />
            Дневник
            {diary.length > 0 && (
              <span className="ml-1 px-1.5 py-0.5 bg-emerald-100 text-emerald-700 rounded-full text-[10px]">
                {diary.length}
              </span>
            )}
          </button>
        </div>

        {/* --- ВКЛАДКА: ПОИСК --- */}
        {activeTab === 'search' && (
          <div className="space-y-6 animate-in fade-in duration-300">
            {/* Форма ввода */}
            <form onSubmit={analyzeDish} className="relative">
              <div className="relative flex items-center shadow-sm rounded-2xl overflow-hidden bg-white border border-slate-200 focus-within:border-emerald-500 focus-within:ring-2 focus-within:ring-emerald-200 transition-all">
                <div className="pl-4 text-slate-400">
                  <Utensils className="w-5 h-5" />
                </div>
                <input
                  type="text"
                  value={dishInput}
                  onChange={(e) => setDishInput(e.target.value)}
                  placeholder="Введите блюдо (например: Салат Цезарь, Пицца...)"
                  className="w-full py-4 px-3 outline-none text-lg text-slate-700 placeholder:text-slate-400 bg-transparent"
                  disabled={loading}
                />
                <button
                  type="submit"
                  disabled={loading || !dishInput.trim()}
                  className="m-2 px-6 py-2.5 bg-emerald-600 hover:bg-emerald-700 disabled:bg-slate-300 disabled:cursor-not-allowed text-white font-medium rounded-xl transition-colors flex items-center gap-2"
                >
                  {loading ? (
                    <Loader2 className="w-5 h-5 animate-spin" />
                  ) : (
                    <Search className="w-5 h-5" />
                  )}
                  <span className="hidden sm:inline">{loading ? 'Анализ...' : 'Оценить'}</span>
                </button>
              </div>
              {error && (
                <div className="absolute top-full left-0 mt-2 flex items-center gap-2 text-rose-500 text-sm">
                  <AlertCircle className="w-4 h-4" />
                  <span>{error}</span>
                </div>
              )}
            </form>

            {/* Список результатов поиска */}
            <div className="space-y-4 pt-2">
              {history.length === 0 && !loading && !error && (
                <div className="text-center py-12 text-slate-400 border-2 border-dashed border-slate-200 rounded-3xl bg-slate-50/50">
                  <PieChart className="w-12 h-12 mx-auto mb-3 text-slate-300" />
                  <p>Здесь появятся результаты анализа ваших блюд.</p>
                </div>
              )}

              {history.map((dish) => (
                <SearchResultCard 
                  key={dish.id} 
                  dish={dish} 
                  onRemove={removeDishFromHistory} 
                  onAddToDiary={addToDiary}
                />
              ))}
            </div>
          </div>
        )}

        {/* --- ВКЛАДКА: ДНЕВНИК --- */}
        {activeTab === 'diary' && (
          <div className="space-y-6 animate-in fade-in duration-300">
            
            {/* Сводка за день */}
            <div className="bg-white rounded-3xl p-6 shadow-sm border border-slate-200 relative overflow-hidden">
              <div className="absolute top-0 right-0 w-32 h-32 bg-emerald-50 rounded-bl-full -z-10 opacity-50"></div>
              
              <div className="flex items-center justify-between mb-6">
                <div className="flex items-center gap-3">
                  <CalendarDays className="w-6 h-6 text-emerald-600" />
                  <h2 className="text-xl font-bold text-slate-800">Сводка за сегодня</h2>
                </div>
              </div>
              
              <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div className="bg-orange-50/80 rounded-2xl p-4 border border-orange-100">
                  <p className="text-sm font-medium text-orange-600/80 mb-1">Калории</p>
                  <p className="text-3xl font-black text-orange-600">{dailyTotals.calories}</p>
                  <p className="text-xs text-orange-600/60 mt-1">ккал</p>
                </div>
                <div className="bg-blue-50/80 rounded-2xl p-4 border border-blue-100">
                  <p className="text-sm font-medium text-blue-600/80 mb-1">Белки</p>
                  <p className="text-3xl font-black text-blue-600">{dailyTotals.protein.toFixed(1)}</p>
                  <p className="text-xs text-blue-600/60 mt-1">грамм</p>
                </div>
                <div className="bg-yellow-50/80 rounded-2xl p-4 border border-yellow-100">
                  <p className="text-sm font-medium text-yellow-600/80 mb-1">Жиры</p>
                  <p className="text-3xl font-black text-yellow-600">{dailyTotals.fat.toFixed(1)}</p>
                  <p className="text-xs text-yellow-600/60 mt-1">грамм</p>
                </div>
                <div className="bg-emerald-50/80 rounded-2xl p-4 border border-emerald-100">
                  <p className="text-sm font-medium text-emerald-600/80 mb-1">Углеводы</p>
                  <p className="text-3xl font-black text-emerald-600">{dailyTotals.carbs.toFixed(1)}</p>
                  <p className="text-xs text-emerald-600/60 mt-1">грамм</p>
                </div>
              </div>

              {/* Секция ИИ-Совета */}
              {diary.length > 0 && (
                <div className="mt-6 pt-6 border-t border-slate-100">
                  {!dietAdvice ? (
                    <button
                      onClick={getNutritionAdvice}
                      disabled={loadingAdvice}
                      className="w-full flex items-center justify-center gap-2 py-3 px-4 bg-gradient-to-r from-indigo-50 to-purple-50 hover:from-indigo-100 hover:to-purple-100 text-indigo-700 font-bold rounded-2xl transition-all border border-indigo-100"
                    >
                      {loadingAdvice ? (
                        <Loader2 className="w-5 h-5 animate-spin" />
                      ) : (
                        <Sparkles className="w-5 h-5 text-indigo-500" />
                      )}
                      ✨ Анализ дня от ИИ-диетолога
                    </button>
                  ) : (
                    <div className="bg-gradient-to-br from-indigo-50 to-purple-50 p-5 rounded-2xl border border-indigo-100 animate-in zoom-in-95 duration-300">
                      <div className="flex items-center gap-2 mb-3 text-indigo-800 font-bold">
                        <MessageSquareHeart className="w-5 h-5" />
                        <h3>Совет диетолога</h3>
                      </div>
                      <p className="text-indigo-900/80 text-sm leading-relaxed whitespace-pre-wrap">
                        {dietAdvice}
                      </p>
                      <button 
                        onClick={getNutritionAdvice}
                        className="mt-4 text-xs font-medium text-indigo-600 hover:text-indigo-800 underline flex items-center gap-1"
                      >
                        <Sparkles className="w-3 h-3" />
                        Обновить совет
                      </button>
                    </div>
                  )}
                </div>
              )}
            </div>

            {/* Список съеденного */}
            <div className="space-y-3">
              <h3 className="text-lg font-bold text-slate-800 px-2">Съедено ({diary.length})</h3>
              
              {diary.length === 0 ? (
                <div className="text-center py-10 text-slate-400 bg-white rounded-3xl border border-slate-100">
                  <p>Ваш дневник пуст. Найдите блюдо и добавьте его сюда!</p>
                  <button 
                    onClick={() => setActiveTab('search')}
                    className="mt-4 px-5 py-2 text-sm bg-slate-100 text-slate-600 hover:bg-slate-200 rounded-xl font-medium transition-colors"
                  >
                    Перейти к поиску
                  </button>
                </div>
              ) : (
                diary.map((entry) => (
                  <div key={entry.id} className="bg-white rounded-2xl p-4 shadow-sm border border-slate-100 flex items-center justify-between group transition-all hover:shadow-md hover:border-emerald-100">
                    <div className="flex-1">
                      <div className="flex items-center gap-2 mb-1">
                        <h4 className="font-bold text-slate-800">{entry.name}</h4>
                        <span className="text-xs px-2 py-0.5 bg-slate-100 text-slate-500 rounded-md">
                          {entry.weight} г
                        </span>
                      </div>
                      <div className="flex gap-4 text-sm text-slate-500 font-medium">
                        <span className="text-orange-600 bg-orange-50 px-2 py-0.5 rounded flex items-center gap-1">
                          <Flame className="w-3 h-3"/>{entry.calories}
                        </span>
                        <span className="hidden sm:inline text-blue-600 bg-blue-50 px-2 py-0.5 rounded">Б: {entry.protein}</span>
                        <span className="hidden sm:inline text-yellow-600 bg-yellow-50 px-2 py-0.5 rounded">Ж: {entry.fat}</span>
                        <span className="hidden sm:inline text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded">У: {entry.carbs}</span>
                      </div>
                    </div>
                    
                    <button 
                      onClick={() => removeFromDiary(entry.id)}
                      className="p-2 text-slate-300 hover:text-rose-500 hover:bg-rose-50 rounded-full transition-colors opacity-100 sm:opacity-0 group-hover:opacity-100 ml-4"
                      title="Удалить из дневника"
                    >
                      <X className="w-5 h-5" />
                    </button>
                  </div>
                ))
              )}
            </div>
            
          </div>
        )}

      </div>
    </div>
  );
}
